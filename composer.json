{
    "name": "idct/symfony-view-projection-normalizer",
    "description": "Symfony MVC View Projection Normalizer - provides DefaultViewProjection attribute and normalizer for intermediate layer between data models and view serialization",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/ideaconnect/symfony-view-projection-normalizer",
    "support": {
        "source": "https://github.com/ideaconnect/symfony-view-projection-normalizer",
        "issues": "https://github.com/ideaconnect/symfony-view-projection-normalizer/issues"
    },
    "autoload": {
        "psr-4": {
            "IDCT\\Mvc\\": "src/"
        }
    },
    "authors": [
        {
            "name": "IDCT Bartosz Pachołek",
            "email": "bartosz+github@idct.tech"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "symfony/serializer": "^7 || ^8",
        "symfony/event-dispatcher": "^7 || ^8",
        "symfony/http-kernel": "^7 || ^8",
        "symfony/service-contracts": "^3",
        "doctrine/common": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0 || ^13.0",
        "symfony/property-access": "^7 || ^8",
        "symfony/property-info": "^7 || ^8",
        "behat/behat": "^3.29",
        "phpspec/prophecy-phpunit": "^2.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload-dev": {
        "psr-4": {
            "IDCT\\Mvc\\Tests\\": "tests/",
            "IDCT\\Mvc\\Tests\\Behat\\": "features/bootstrap/",
            "IDCT\\Mvc\\Tests\\Behat\\Fixtures\\": "features/fixtures/"
        }
    },
    "scripts": {
        "format": "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --verbose",
        "format:check": "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --verbose",
        "test:static": "./vendor/bin/phpstan analyse -c phpstan.neon",
        "test:unit": "./vendor/bin/phpunit tests/Unit",
        "test:feature": "./vendor/bin/behat",
        "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-clover=coverage/clover.xml --coverage-html=coverage/html"
    }
}
